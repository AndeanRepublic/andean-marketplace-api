{
	"moduleFileExtensions": ["js", "json", "ts"],
	"rootDir": ".",
	"testMatch": ["<rootDir>/unit/**/*.spec.ts"],
	"testEnvironment": "node",
	"transform": {
		"^.+\\.(t|j)s$": "ts-jest"
	},
	"moduleNameMapper": {
		"^src/(.*)$": "<rootDir>/../src/$1"
	},
	"collectCoverageFrom": [
		"<rootDir>/../src/**/*.(t|j)s",
		"!<rootDir>/../src/**/*.spec.(t|j)s"
	],
	"coverageDirectory": "<rootDir>/coverage-unit"
}
