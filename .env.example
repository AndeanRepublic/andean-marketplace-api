# Andean Marketplace API - Environment Variables

# Server
PORT=3000
# Lista de origins permitidos separados por coma (sin espacios entre URLs)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# MongoDB
MONGO_URI=mongodb://localhost:27017/andean-marketplace

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_ISSUER=andean-marketplace

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=andean-marketplace-uploads

# Storage Base URL
STORAGE_BASE_URL=https://andean-marketplace-uploads.s3.us-east-1.amazonaws.com

# Upload Configuration (optional)
UPLOAD_MAX_SIZE_MB=5

# Segmind API (IDM-VTON Virtual Try-On)
SEGMIND_API_KEY=your-segmind-api-key
